{
  "moduleId": "zorbit-cor-authorization",
  "moduleName": "Authorization Service",
  "moduleType": "cor",
  "version": "1.0.0",
  "placement": {
    "scaffold": "Platform Core",
    "scaffoldSortOrder": 10,
    "capabilityArea": "Authorization",
    "sortOrder": 20
  },
  "registration": {
    "kafkaTopic": "platform-module-announcements",
    "manifestUrl": "https://zorbit-uat.onezippy.ai/api/authorization/api/v1/G/manifest"
  },
  "navigation": {
    "sections": [
      {
        "label": "Authorization",
        "icon": "security",
        "sortOrder": 2,
        "items": [
          {
            "label": "Roles",
            "feRoute": "/m/authorization/roles",
            "beRoute": "/api/authorization/api/v1/O/{{org_id}}/roles",
            "privilege": "authorization.role.read",
            "icon": "admin_panel_settings"
          },
          {
            "label": "Privileges",
            "feRoute": "/m/authorization/privileges",
            "beRoute": "/api/authorization/api/v1/G/privileges",
            "privilege": "authorization.privilege.read",
            "icon": "verified_user"
          },
          {
            "label": "User Roles",
            "feRoute": "/m/authorization/user-roles",
            "beRoute": "/api/authorization/api/v1/O/{{org_id}}/user-roles",
            "privilege": "authorization.user_role.read",
            "icon": "manage_accounts"
          }
        ]
      }
    ]
  },
  "dependencies": [
    "zorbit-cor-identity"
  ],
  "backend": {
    "healthEndpoint": "/api/authorization/api/v1/G/health",
    "apiPrefix": "/api/authorization/api/v1"
  }
}

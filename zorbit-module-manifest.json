{
  "db": {
    "dbName": "zorbit_authorization",
    "dbType": "postgres",
    "operations": {
      "backup": {
        "method": "POST",
        "beRoute": "/api/authorization/api/v1/G/db/backup",
        "privilege": "authorization.db.backup"
      },
      "restore": {
        "method": "POST",
        "beRoute": "/api/authorization/api/v1/G/db/restore",
        "privilege": "authorization.db.restore",
        "destructive": true
      },
      "flushAllData": {
        "method": "DELETE",
        "beRoute": "/api/authorization/api/v1/G/seed/all",
        "privilege": "authorization.seed.all",
        "destructive": true
      },
      "seedDemoData": {
        "method": "POST",
        "beRoute": "/api/authorization/api/v1/G/seed/demo",
        "privilege": "authorization.seed.demo"
      },
      "flushDemoData": {
        "method": "DELETE",
        "beRoute": "/api/authorization/api/v1/G/seed/demo",
        "privilege": "authorization.seed.demo"
      },
      "seedSystemMin": {
        "method": "POST",
        "beRoute": "/api/authorization/api/v1/G/seed/system-min",
        "privilege": "authorization.seed.system-min"
      }
    }
  },
